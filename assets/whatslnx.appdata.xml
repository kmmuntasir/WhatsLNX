<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.kmmuntasir.WhatsLNX</id>
  <name>WhatsLNX</name>
  <summary>Unofficial WhatsApp desktop client for Linux</summary>
  <developer_name>Muntasir Billah Munna</developer_name>
  <project_license>GPL-3.0</project_license>
  <metadata_license>CC0-1.0</metadata_license>
  <url type="homepage">https://github.com/kmmuntasir/WhatsLNX</url>
  <url type="bugtracker">https://github.com/kmmuntasir/WhatsLNX/issues</url>
  <url type="vcs-browser">https://github.com/kmmuntasir/WhatsLNX</url>

  <description>
    <p>
      WhatsLNX is a minimalist, high-performance unofficial WhatsApp desktop
      client for Linux. It wraps WhatsApp Web inside a tailored Electron shell
      that prioritizes system-native behavior, Wayland compatibility, and
      flawless WebRTC (audio/video calling) support.
    </p>
    <p>Features:</p>
    <ul>
      <li>Automatic Wayland and X11 support — no manual configuration required</li>
      <li>Audio and video calling with automatic camera and microphone permissions</li>
      <li>Native system notifications via DBus</li>
      <li>Native file dialogs via xdg-desktop-portal</li>
      <li>Automatic dark/light theme sync with your desktop environment</li>
      <li>Configurable font families (Serif, Sans-Serif, Monospace)</li>
      <li>System tray icon with unread message count</li>
      <li>Drag-and-drop file support from your file manager</li>
      <li>whatsapp:// deep link protocol handler</li>
      <li>Session persistence — stay logged in between restarts</li>
      <li>Single instance lock — prevents duplicate windows</li>
      <li>Auto-update support for AppImage releases</li>
    </ul>
  </description>

  <launchable type="desktop-id">whatslnx.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>WhatsLNX main window showing WhatsApp Web</caption>
      <image type="source">https://raw.githubusercontent.com/kmmuntasir/WhatsLNX/main/assets/screenshots/main.png</image>
    </screenshot>
  </screenshots>

  <categories>
    <category>Network</category>
    <category>InstantMessaging</category>
    <category>Chat</category>
  </categories>

  <keywords>
    <keyword>whatsapp</keyword>
    <keyword>chat</keyword>
    <keyword>messenger</keyword>
    <keyword>message</keyword>
    <keyword>im</keyword>
  </keywords>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
    <content_attribute id="social-contacts">intense</content_attribute>
  </content_rating>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <releases>
    <release version="0.2.0" date="2026-05-24" type="development">
      <description>
        <p>Phase 2: Native integration build.</p>
        <ul>
          <li>Native notification bubbles via DBus</li>
          <li>Settings window with font configuration</li>
          <li>Theme override (System/Light/Dark)</li>
          <li>Drag-and-drop file support</li>
          <li>Native file dialogs via xdg-desktop-portal</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-24" type="development">
      <description>
        <p>Initial MVP release.</p>
        <ul>
          <li>WhatsApp Web wrapper with session persistence</li>
          <li>Wayland auto-detection</li>
          <li>System tray icon</li>
          <li>whatsapp:// deep link handler</li>
          <li>User-Agent spoofing</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
